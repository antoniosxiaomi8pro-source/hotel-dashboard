# Environment Variables Template
# Copy this file to .env and fill in your actual values
# .env file is NOT tracked by git (see .gitignore)

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-api-key

# ============================================================================
# GITHUB CONFIGURATION (optional, for deployment)
# ============================================================================
GITHUB_TOKEN=your-github-token-here

# ============================================================================
# DATABASE USERS (Demo credentials - change these immediately!)
# ============================================================================
# Format: EMAIL:PASSWORD_HASH (use secure passwords in production)
ADMIN_EMAIL=admin@cosmhotel.gr
ADMIN_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

GROUP_MANAGER_EMAIL=group@cosmhotel.gr
GROUP_MANAGER_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
